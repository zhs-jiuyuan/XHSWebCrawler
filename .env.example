# XHSWebCrawler 环境变量配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env

# Scrapy 运行环境 (对应 config/{name}.yaml)
SCRAPY_ENV=base

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/scrapy.log

# PostgreSQL 连接串
POSTGRES_URL=postgresql://user:password@localhost:5432/crawl_data

# Redis 连接串
REDIS_URL=redis://:password@localhost:6379/0

# --- 以下为可选配置 ---

# 代理 API 地址
# PROXY_API_URL=http://localhost:5010/get

# 是否启用代理
# PROXY_ENABLED=false
